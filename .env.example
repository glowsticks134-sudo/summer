# ============================================================
# 2026 Summer Break Event Bot — Environment Variables
# ============================================================
# Copy this file, fill in the values, and add them to Railway
# under your service → Variables tab.
# ============================================================


# ------------------------------------------------------------
# DATABASE (Required)
# ------------------------------------------------------------
# Production database: Neon Postgres (external, pooled connection).
# Set this value in Railway → service → Variables tab.
# Do NOT commit the real password to version control.
#
# Connection format (Neon pooled):
#   postgresql://<user>:<password>@<host>/<dbname>?sslmode=require&channel_binding=require
#
# The production Neon project uses:
#   host:   ep-delicate-moon-aqf5p9wu-pooler.c-8.us-east-1.aws.neon.tech
#   dbname: neondb
#   user:   neondb_owner
#
# For local development you can use a local Postgres instance or a
# personal Neon branch. Retrieve the password from the Neon console
# (project → Connection Details → pooled connection string).
DATABASE_URL=postgresql://neondb_owner:<password>@ep-delicate-moon-aqf5p9wu-pooler.c-8.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require


# ------------------------------------------------------------
# DISCORD BOT (Required)
# ------------------------------------------------------------
# DISCORD_BOT_TOKEN:
#   1. Go to https://discord.com/developers/applications
#   2. Select your app → Bot → Reset Token → Copy it
#
# DISCORD_GUILD_ID:
#   Your server's ID. In Discord: right-click your server name
#   → Copy Server ID (enable Developer Mode in Settings → Advanced)
#
# IMPORTANT: In the Developer Portal → Bot → Privileged Gateway Intents
# you must enable BOTH:
#   ✅ Server Members Intent
#   ✅ Message Content Intent
DISCORD_BOT_TOKEN=your-bot-token-here

# DISCORD_GUILD_ID is now optional — the bot works in all servers it joins.
# If set, slash commands will also be registered as guild commands for instant
# availability (global commands can take up to 1 hour to propagate).
DISCORD_GUILD_ID=your-server-id-here

# The Discord user ID of the bot owner. Only this user can run admin commands.
# Right-click yourself in Discord → Copy User ID (enable Developer Mode first).
DISCORD_OWNER_ID=your-discord-user-id-here


# ------------------------------------------------------------
# SESSION SECRET (Required)
# ------------------------------------------------------------
# Any long random string. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string


# ------------------------------------------------------------
# NODE ENVIRONMENT (Required)
# ------------------------------------------------------------
# Set to "production" on Railway.
NODE_ENV=production


# ------------------------------------------------------------
# PORT (Do NOT set on Railway)
# ------------------------------------------------------------
# Railway injects PORT automatically. Only set this for local
# development if you need to override the default.
# PORT=8080
